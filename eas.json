{
  "cli": {
    "version": ">= 18.13.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android":{
        "buildType":"apk"
      },
      "env":{
        "API_URL":"http://localhost:3000"
      }
    },
    "preview": {
      "android":{
        "buildType":"apk"
      },
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
